---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  titleZh?: string;
  date: Date;
  updated?: Date;
  tags: string[];
  tagsZh?: string[];
}

const { title, titleZh, date, updated, tags, tagsZh } = Astro.props;
const fmtEn = (d: Date) => d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const fmtZh = (d: Date) => d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
const formattedDateEn = fmtEn(date);
const formattedDateZh = fmtZh(date);
const formattedUpdatedEn = updated ? fmtEn(updated) : null;
const formattedUpdatedZh = updated ? fmtZh(updated) : null;
---

<BaseLayout title={`${title} — Yumin Cao`}>
  <article class="container post">
    <header class="post-header">
      <time class="post-date" datetime={date.toISOString()}>
        <span class="lang-en">{formattedDateEn}</span><span class="lang-zh">{formattedDateZh}</span>
      </time>
      {formattedUpdatedEn && (
        <span class="post-updated">（<span class="lang-en">updated {formattedUpdatedEn}</span><span class="lang-zh">更新于 {formattedUpdatedZh}</span>）</span>
      )}
      <h1 class="post-title">
        <span class="lang-en">{title}</span>
        {titleZh && <span class="lang-zh">{titleZh}</span>}
      </h1>
      <div class="post-tags">
        {tags.length > 0 && (
          <span class="lang-en">
            {tags.map(tag => (
              <span class="post-tag">{tag}</span>
            ))}
          </span>
        )}
        {tagsZh && tagsZh.length > 0 && (
          <span class="lang-zh">
            {tagsZh.map(tag => (
              <span class="post-tag">{tag}</span>
            ))}
          </span>
        )}
      </div>
    </header>
    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding-top: 48px;
    padding-bottom: 48px;
    max-width: 720px;
  }

  .post-header {
    margin-bottom: 40px;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent-blog);
  }

  .post-updated {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-left: 6px;
  }

  .post-title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    margin-top: 8px;
    margin-bottom: 12px;
    line-height: 1.3;
  }

  :global(html[data-lang="zh"]) .post-title {
    line-height: 1.5;
  }

  .post-tags {
    display: flex;
    gap: 6px;
  }

  .post-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent-blog);
    background: color-mix(in srgb, var(--accent-blog) 12%, transparent);
    padding: 2px 8px;
    border-radius: 4px;
  }

  .post-content {
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  /* Chinese: slightly larger body for readability */
  :global(html[data-lang="zh"]) .post-content {
    line-height: 2;
    letter-spacing: 0.03em;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    margin-top: 48px;
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--card-border);
  }

  .post-content :global(h3) {
    font-size: 1.25rem;
    margin-top: 36px;
    margin-bottom: 14px;
  }

  .post-content :global(h4) {
    font-size: 1.0625rem;
    margin-top: 28px;
    margin-bottom: 10px;
  }

  .post-content :global(p) {
    margin-bottom: 20px;
  }

  /* Inline code */
  .post-content :global(:not(pre) > code) {
    font-size: 0.85em;
    background: color-mix(in srgb, var(--accent-blog) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-blog) 15%, transparent);
    padding: 2px 6px;
    border-radius: 4px;
    font-weight: 500;
  }

  /* Code blocks */
  .post-content :global(pre) {
    background: color-mix(in srgb, var(--bg-primary) 70%, black);
    border: 1px solid var(--card-border);
    border-radius: var(--border-radius-inner);
    padding: 20px;
    overflow-x: auto;
    margin-bottom: 24px;
    font-size: 0.875rem;
    line-height: 1.65;
  }

  .post-content :global(pre code) {
    font-size: inherit;
    background: none;
    border: none;
    padding: 0;
    font-weight: 400;
  }

  /* Links */
  .post-content :global(a) {
    color: var(--accent-blog);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: color-mix(in srgb, var(--accent-blog) 40%, transparent);
    transition: text-decoration-color 0.2s;
  }

  .post-content :global(a:hover) {
    text-decoration-color: var(--accent-blog);
  }

  /* Blockquotes */
  .post-content :global(blockquote) {
    border-left: 3px solid var(--accent-blog);
    padding: 4px 0 4px 20px;
    color: var(--text-muted);
    margin-bottom: 24px;
    font-style: italic;
  }

  .post-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  /* Lists */
  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 20px;
    padding-left: 1.5em;
  }

  .post-content :global(li) {
    margin-bottom: 8px;
    line-height: 1.7;
  }

  .post-content :global(li > ul),
  .post-content :global(li > ol) {
    margin-top: 8px;
    margin-bottom: 0;
  }

  /* Horizontal rule */
  .post-content :global(hr) {
    border: none;
    height: 1px;
    background: var(--card-border);
    margin: 40px 0;
  }

  /* Images */
  .post-content :global(img) {
    border-radius: var(--border-radius-inner);
    margin: 28px 0;
    border: 1px solid var(--card-border);
  }

  /* Tables */
  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 24px;
    font-size: 0.9375rem;
  }

  .post-content :global(th) {
    text-align: left;
    font-weight: 600;
    padding: 10px 14px;
    border-bottom: 2px solid var(--card-border);
    color: var(--text-heading);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: var(--font-mono);
  }

  .post-content :global(td) {
    padding: 10px 14px;
    border-bottom: 1px solid var(--card-border);
  }

  .post-content :global(tr:hover td) {
    background: color-mix(in srgb, var(--accent-blog) 4%, transparent);
  }

  /* Strong / Bold */
  .post-content :global(strong) {
    font-weight: 600;
    color: var(--text-heading);
  }

  /* Emphasis */
  .post-content :global(em) {
    font-style: italic;
  }

  /* Chinese: skip italic for emphasis, use bold instead */
  :global(html[data-lang="zh"]) .post-content :global(em) {
    font-style: normal;
    font-weight: 600;
    color: var(--text-heading);
  }
</style>
