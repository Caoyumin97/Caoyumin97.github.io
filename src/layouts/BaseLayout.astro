---
import { ClientRouter } from 'astro:transitions';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import BlobBackground from '../components/BlobBackground.astro';
import '../styles/global.css';
import '../styles/animations.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Yumin Cao — AI agent engineer at Xiaomi. Building agents, writing about what that means. | 曹宇旻 — 小米 AI Agent 工程师' } = Astro.props;
---

<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- English: Fraunces (headings) + Literata (body) + Fira Code (code) -->
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Literata:opsz,wght@7..72,400;7..72,500;7..72,600;7..72,700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />
    <!-- Chinese: Noto Serif SC 思源宋体 (classic serif for scholarly feel) -->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <script is:inline>
      (function() {
        function getTheme() {
          return localStorage.getItem('theme') ||
            (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        }
        function getLang() {
          return localStorage.getItem('lang') || 'en';
        }
        function apply() {
          var lang = getLang();
          document.documentElement.setAttribute('data-theme', getTheme());
          document.documentElement.setAttribute('data-lang', lang);
          document.documentElement.setAttribute('lang', lang);
        }
        // Apply immediately on initial load (prevents FOUC)
        apply();
        // Re-apply after Astro swaps the DOM on client-side navigation
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>
    <ClientRouter />
    <script src="../scripts/scroll-reveal.ts"></script>
    <script src="../scripts/easter-eggs.ts"></script>
  </head>
  <body>
    <BlobBackground />
    <NavBar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
