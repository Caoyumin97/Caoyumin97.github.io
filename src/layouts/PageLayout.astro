---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  pageTitle?: string;
  pageTitleZh?: string;
}

const { title, description, pageTitle, pageTitleZh } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="container page">
    {pageTitle && (
      <h1 class="page-title">
        <span class="lang-en">{pageTitle}</span>{pageTitleZh && <span class="lang-zh">{pageTitleZh}</span>}
      </h1>
    )}
    <slot />
  </div>
</BaseLayout>

<style>
  .page {
    padding-top: 48px;
    padding-bottom: 48px;
  }

  .page-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    margin-bottom: 32px;
  }
</style>
