---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { pairByLang } from '../../utils/i18n';

const posts = (await getCollection('blog', ({ data }) => !data.draft));
const pairs = pairByLang(posts);

// Sort pairs by date (use whichever version exists)
const sortedPairs = [...pairs.entries()]
  .map(([key, pair]) => ({ key, ...pair }))
  .sort((a, b) => {
    const dateA = (a.en ?? a.zh)!.data.date.getTime();
    const dateB = (b.en ?? b.zh)!.data.date.getTime();
    return dateB - dateA;
  });

const fmtEn = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const fmtZh = (d: Date) => d.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric', year: 'numeric' });
---

<PageLayout title="Blog — Yumin Cao" pageTitle="Blog" pageTitleZh="博客" accent="var(--accent-blog)">
  <div class="posts-list">
    {sortedPairs.map(({ key, en, zh }) => {
      const primary = en ?? zh!;
      const date = primary.data.date;
      const updated = primary.data.updated;
      return (
        <a href={`/blog/${key}`} class="post-preview">
          <time class="preview-date">
            <span class="lang-en">{fmtEn(date)}</span>
            <span class="lang-zh">{fmtZh(date)}</span>
          </time>
          {updated && (
            <span class="preview-updated">（<span class="lang-en">updated {fmtEn(updated)}</span><span class="lang-zh">更新于 {fmtZh(updated)}</span>）</span>
          )}
          <h3 class="preview-title">
            <span class="lang-en">{en?.data.title ?? primary.data.title}</span>
            {zh && <span class="lang-zh">{zh.data.title}</span>}
          </h3>
          <p class="preview-excerpt">
            <span class="lang-en">{en?.data.excerpt ?? primary.data.excerpt}</span>
            {zh && <span class="lang-zh">{zh.data.excerpt}</span>}
          </p>
          <div class="preview-tags">
            {en && en.data.tags.length > 0 && (
              <span class="lang-en">
                {en.data.tags.map(tag => (
                  <span class="preview-tag">{tag}</span>
                ))}
              </span>
            )}
            {zh && zh.data.tags.length > 0 && (
              <span class="lang-zh">
                {zh.data.tags.map(tag => (
                  <span class="preview-tag">{tag}</span>
                ))}
              </span>
            )}
          </div>
        </a>
      );
    })}
  </div>
</PageLayout>

<style>
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .post-preview {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--card-border);
    border-radius: var(--border-radius-card);
    padding: 24px;
    transition: border-color 0.3s;
  }

  .post-preview:hover {
    border-color: color-mix(in srgb, var(--accent-blog) 25%, transparent);
  }

  .preview-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-blog);
  }

  .preview-updated {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-muted);
    margin-left: 4px;
  }

  .preview-title {
    font-size: 1.25rem;
    margin-top: 4px;
    margin-bottom: 6px;
  }

  .preview-excerpt {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .preview-tags {
    display: flex;
    gap: 6px;
    margin-top: 10px;
  }

  .preview-tag {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--text-muted);
    background: color-mix(in srgb, var(--text-muted) 8%, transparent);
    padding: 2px 6px;
    border-radius: 3px;
  }
</style>
