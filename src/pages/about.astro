---
import PageLayout from '../layouts/PageLayout.astro';
import Timeline from '../components/Timeline.astro';
import T from '../components/T.astro';

const experience = [
  {
    role: 'Head of AI Applications',
    roleZh: 'AI 应用负责人',
    company: 'Xiaomi — Supply Chain Management',
    companyZh: '小米 — 供应链管理',
    period: '2024 — Present',
    description: 'Leading the AI applications team in supply chain. Building Agent-based systems that shorten the loop from information to decision to execution — cross-system aggregation, natural-language-to-SQL, automated replenishment, and human-Agent hybrid workflows.',
    descriptionZh: '负责供应链 AI 应用团队，构建基于 Agent 的系统，缩短从信息到决策到执行的链路——跨系统聚合、自然语言转 SQL、自动补货、人机协作工作流。',
  },
  {
    role: 'Algorithm Engineer',
    roleZh: '算法工程师',
    company: 'Xiaomi — Supply Chain Management',
    companyZh: '小米 — 供应链管理',
    period: '2022 — 2024',
    description: 'Built ML models for demand forecasting, inventory optimization, and logistics routing. Published research on transportation and urban computing.',
    descriptionZh: '构建需求预测、库存优化和物流路径规划的机器学习模型。发表交通与城市计算方向的研究论文。',
  },
];

const education = [
  {
    degree: 'M.S. Computer Science',
    degreeZh: '计算机科学硕士',
    school: 'University of Chinese Academy of Sciences',
    schoolZh: '中国科学院大学',
    period: '2019 — 2022',
  },
  {
    degree: 'B.E. Transportation Engineering',
    degreeZh: '交通工程学士',
    school: 'Southeast University',
    schoolZh: '东南大学',
    period: '2015 — 2019',
  },
];
---

<PageLayout title="About — Yumin Cao" pageTitle="About" pageTitleZh="关于">
  <section class="about-bio reveal">
    <p class="lang-en">
      I'm Yumin — an engineer who went from studying how cities move to building AI agents that actually do things.
      By day I lead AI applications for Xiaomi's supply chain, where I deploy Agents that handle everything
      from demand forecasting to automated procurement. By night (and weekends) I build personal tools with
      AI coding agents, think too hard about what "software" means when anyone can make it, and occasionally
      reference Heidegger in blog posts about CLI tools.
    </p>
    <p class="lang-en">
      My background is in transportation ML — using machine learning to understand how people and goods flow
      through cities. That foundation in optimization and systems thinking turned out to be surprisingly useful
      when the job shifted to "make AI agents do supply chain operations without breaking everything."
    </p>
    <p class="lang-zh">
      我是宇旻——一个从研究城市如何运转，到构建真正能干活的 AI Agent 的工程师。
      白天在小米供应链负责 AI 应用，部署处理需求预测到自动采购全链路的 Agent 系统。
      晚上和周末用 AI 编程工具造自己的工具，过度思考"当所有人都能造软件时，软件意味着什么"，
      偶尔在写 CLI 工具的博客里引用海德格尔。
    </p>
    <p class="lang-zh">
      我的研究背景是交通机器学习——用 ML 理解人和货物如何在城市中流动。
      这个优化与系统思维的基础，在工作转向"让 AI Agent 做供应链运营而不搞砸一切"之后，
      意外地派上了大用场。
    </p>
  </section>

  <section class="about-section">
    <h2 class="about-heading"><T en="Experience" zh="工作经历" /></h2>
    <div class="timeline">
      {experience.map(entry => (
        <div class="timeline-entry reveal">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <h3 class="timeline-role">
              <span class="lang-en">{entry.role}</span>
              <span class="lang-zh">{entry.roleZh}</span>
            </h3>
            <p class="timeline-company">
              <span class="lang-en">{entry.company}</span>
              <span class="lang-zh">{entry.companyZh}</span>
            </p>
            <time class="timeline-period">{entry.period}</time>
            <p class="timeline-desc">
              <span class="lang-en">{entry.description}</span>
              <span class="lang-zh">{entry.descriptionZh}</span>
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="about-section reveal">
    <h2 class="about-heading"><T en="Education" zh="教育背景" /></h2>
    <div class="education-list">
      {education.map(entry => (
        <div class="edu-entry">
          <h3 class="edu-degree">
            <span class="lang-en">{entry.degree}</span>
            <span class="lang-zh">{entry.degreeZh}</span>
          </h3>
          <p class="edu-school">
            <span class="lang-en">{entry.school}</span>
            <span class="lang-zh">{entry.schoolZh}</span>
          </p>
          <time class="edu-period">{entry.period}</time>
        </div>
      ))}
    </div>
  </section>

  <section class="about-section reveal">
    <h2 class="about-heading"><T en="Skills & Tools" zh="技能与工具" /></h2>
    <div class="skills-grid">
      <div class="skill-group">
        <h3 class="skill-group-label"><T en="AI / ML" zh="AI / ML" /></h3>
        <div class="skill-tags">
          <span class="skill-tag">LLM Agents</span>
          <span class="skill-tag">MCP</span>
          <span class="skill-tag">Claude Code</span>
          <span class="skill-tag">Demand Forecasting</span>
          <span class="skill-tag">Optimization</span>
        </div>
      </div>
      <div class="skill-group">
        <h3 class="skill-group-label"><T en="Languages" zh="编程语言" /></h3>
        <div class="skill-tags">
          <span class="skill-tag">Python</span>
          <span class="skill-tag">TypeScript</span>
          <span class="skill-tag">SQL</span>
        </div>
      </div>
      <div class="skill-group">
        <h3 class="skill-group-label"><T en="Stack" zh="技术栈" /></h3>
        <div class="skill-tags">
          <span class="skill-tag">FastAPI</span>
          <span class="skill-tag">React</span>
          <span class="skill-tag">Next.js</span>
          <span class="skill-tag">Node.js</span>
          <span class="skill-tag">Astro</span>
          <span class="skill-tag">SQLite</span>
          <span class="skill-tag">PostgreSQL</span>
        </div>
      </div>
      <div class="skill-group">
        <h3 class="skill-group-label"><T en="Interests" zh="兴趣" /></h3>
        <div class="skill-tags">
          <span class="skill-tag"><T en="Photography" zh="摄影" /></span>
          <span class="skill-tag"><T en="Trail Running" zh="越野跑" /></span>
          <span class="skill-tag"><T en="Music" zh="音乐" /></span>
          <span class="skill-tag"><T en="Philosophy of Tech" zh="技术哲学" /></span>
        </div>
      </div>
    </div>
  </section>

  <section class="about-section reveal">
    <h2 class="about-heading"><T en="Get in Touch" zh="联系我" /></h2>
    <p class="about-contact lang-en">
      Find me on
      <a href="https://github.com/Caoyumin97" target="_blank" rel="noopener" class="link-fancy">GitHub</a>,
      <a href="https://scholar.google.com/citations?user=2hOjd60AAAAJ" target="_blank" rel="noopener" class="link-fancy">Google Scholar</a>, or
      <a href="https://www.linkedin.com/in/yumin-cao/" target="_blank" rel="noopener" class="link-fancy">LinkedIn</a>.
    </p>
    <p class="about-contact lang-zh">
      你可以在
      <a href="https://github.com/Caoyumin97" target="_blank" rel="noopener" class="link-fancy">GitHub</a>、
      <a href="https://scholar.google.com/citations?user=2hOjd60AAAAJ" target="_blank" rel="noopener" class="link-fancy">Google Scholar</a> 或
      <a href="https://www.linkedin.com/in/yumin-cao/" target="_blank" rel="noopener" class="link-fancy">LinkedIn</a> 上找到我。
    </p>
  </section>
</PageLayout>

<style>
  .about-bio {
    font-size: 1.125rem;
    line-height: 1.8;
    max-width: 640px;
    margin-bottom: 48px;
  }

  .about-bio p {
    margin-bottom: 16px;
  }

  .about-section {
    margin-bottom: 48px;
  }

  .about-heading {
    font-size: 1.5rem;
    margin-bottom: 24px;
    color: var(--accent-about);
  }

  .about-contact {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-muted);
  }

  .about-contact a {
    color: var(--accent-about);
  }

  /* Timeline (inline since we need bilingual support) */
  .timeline {
    position: relative;
    padding-left: 32px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--card-border);
  }

  .timeline-entry {
    position: relative;
    margin-bottom: 32px;
  }

  .timeline-entry:last-child {
    margin-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: -28px;
    top: 6px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--accent-about);
    border: 2px solid var(--bg-primary);
  }

  .timeline-role {
    font-size: 1.125rem;
    margin-bottom: 2px;
  }

  .timeline-company {
    font-size: 0.9375rem;
    color: var(--accent-about);
  }

  .timeline-period {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    display: block;
    margin-top: 4px;
    margin-bottom: 8px;
  }

  .timeline-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .education-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .edu-degree {
    font-size: 1.125rem;
    margin-bottom: 2px;
  }

  .edu-school {
    font-size: 0.9375rem;
    color: var(--accent-about);
  }

  .edu-period {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    display: block;
    margin-top: 4px;
  }

  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .skill-group-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 8px;
  }

  .skill-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .skill-tag {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent-about);
    background: color-mix(in srgb, var(--accent-about) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-about) 18%, transparent);
    padding: 6px 14px;
    border-radius: 20px;
  }
</style>
