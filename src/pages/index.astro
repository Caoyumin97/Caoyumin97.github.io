---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeSection from '../components/HomeSection.astro';
import GlassCard from '../components/GlassCard.astro';
import NowPlaying from '../components/NowPlaying.astro';
import T from '../components/T.astro';
import { getCollection } from 'astro:content';
import { pairByLang } from '../utils/i18n';

const allPapersRaw = await getCollection('papers');
const featured = allPapersRaw.filter(p => p.data.featured).sort((a, b) => b.data.year - a.data.year);
const allPapers = featured.length > 0
  ? featured.slice(0, 3)
  : allPapersRaw.sort((a, b) => b.data.year - a.data.year).slice(0, 3);

const allProjectsRaw = await getCollection('projects');
const projectPairs = [...pairByLang(allProjectsRaw).entries()]
  .map(([key, pair]) => ({ key, ...pair }))
  .filter(p => (p.en ?? p.zh)!.data.featured);

const allPostsRaw = await getCollection('blog', ({ data }) => !data.draft);
const blogPairs = [...pairByLang(allPostsRaw).entries()]
  .map(([key, pair]) => ({ key, ...pair }))
  .sort((a, b) => {
    const dateA = (a.en ?? a.zh)!.data.date.getTime();
    const dateB = (b.en ?? b.zh)!.data.date.getTime();
    return dateB - dateA;
  });
const latestPosts = blogPairs.slice(0, 3);

const fmtEn = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
const fmtZh = (d: Date) => d.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' });
---

<BaseLayout title="Yumin Cao">
  <div class="container">

    <!-- Hero -->
    <section class="hero">
      <h1 class="hero-name">
        <span class="word" style="animation-delay: 0s">Yumin</span>
        <span class="word" style="animation-delay: 0.1s">Cao</span>
      </h1>
      <p class="hero-role">
        <span class="lang-en">AI Agent Engineer @ Xiaomi</span>
        <span class="lang-zh">小米 AI Agent 工程师</span>
      </p>
      <p id="hero-tagline" class="hero-tagline">
        <span class="lang-en">I build agents that do things, then write about what that means.</span>
        <span class="lang-zh">造能干活的 Agent，然后想想这意味着什么。</span>
      </p>
      <div class="hero-gradient-line"></div>
      <div class="hero-social">
        <a href="https://github.com/Caoyumin97" target="_blank" rel="noopener" class="social-pill">GitHub</a>
        <a href="https://scholar.google.com/citations?user=2hOjd60AAAAJ" target="_blank" rel="noopener" class="social-pill">Scholar</a>
        <a href="https://www.linkedin.com/in/yumin-cao/" target="_blank" rel="noopener" class="social-pill">LinkedIn</a>
      </div>
      <NowPlaying />
    </section>

    <!-- Blog (strongest content, shown first) -->
    <HomeSection label="Blog" labelZh="博客" accent="var(--accent-blog)" href="/blog">
      <div class="blog-list">
        {latestPosts.map(({ key, en, zh }) => {
          const primary = en ?? zh!;
          const date = primary.data.date;
          return (
            <GlassCard accent="var(--accent-blog)" href={`/blog/${key}`}>
              <div class="blog-card-inner">
                <time class="blog-date">
                  <span class="lang-en">{fmtEn(date)}</span>
                  <span class="lang-zh">{fmtZh(date)}</span>
                </time>
                <p class="card-title">
                  <span class="lang-en">{en?.data.title ?? primary.data.title}</span>
                  {zh && <span class="lang-zh">{zh.data.title}</span>}
                </p>
                <p class="card-meta">
                  <span class="lang-en">{en?.data.excerpt ?? primary.data.excerpt}</span>
                  {zh && <span class="lang-zh">{zh.data.excerpt}</span>}
                </p>
              </div>
            </GlassCard>
          );
        })}
      </div>
    </HomeSection>

    <!-- Projects -->
    <HomeSection label="Projects" labelZh="项目" accent="var(--accent-projects)" href="/projects">
      <div class="cards-grid">
        {projectPairs.length > 0 ? projectPairs.map(({ key, en, zh }) => {
          const primary = en ?? zh!;
          return (
            <GlassCard accent="var(--accent-projects)" href={`/projects/${key}`}>
              <p class="card-title">
                <span class="lang-en">{en?.data.title ?? primary.data.title}</span>
                {zh && <span class="lang-zh">{zh.data.title}</span>}
              </p>
              <p class="card-meta">
                <span class="lang-en">{en?.data.description ?? primary.data.description}</span>
                {zh && <span class="lang-zh">{zh.data.description}</span>}
              </p>
            </GlassCard>
          );
        }) : (
          <GlassCard accent="var(--accent-projects)">
            <p class="card-meta"><T en="Coming soon..." zh="即将到来..." /></p>
          </GlassCard>
        )}
      </div>
    </HomeSection>

    <!-- Papers -->
    <HomeSection label="Papers" labelZh="论文" accent="var(--accent-papers)" href="/papers">
      <div class="cards-list">
        {allPapers.length > 0 ? allPapers.map(paper => (
          <GlassCard accent="var(--accent-papers)" href="/papers">
            <p class="card-title">{paper.data.title}</p>
            <p class="card-meta">{paper.data.venue} · {paper.data.year}</p>
          </GlassCard>
        )) : (
          <GlassCard accent="var(--accent-papers)">
            <p class="card-meta"><T en="Coming soon..." zh="即将到来..." /></p>
          </GlassCard>
        )}
      </div>
    </HomeSection>

    <!-- Life -->
    <HomeSection label="Life" labelZh="生活" accent="var(--accent-life)" href="/life">
      <GlassCard accent="var(--accent-life)" href="/life">
        <p class="card-meta life-teaser">
          <span class="lang-en">Trail running, photography, music that makes you stare at the ceiling. The non-code parts.</span>
          <span class="lang-zh">越野跑、摄影、让你盯着天花板发呆的音乐。代码之外的部分。</span>
        </p>
      </GlassCard>
    </HomeSection>

  </div>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    text-align: left;
    padding-top: 80px;
    padding-bottom: 64px;
  }

  .hero-name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 8px;
    display: flex;
    justify-content: flex-start;
    gap: 0.3em;
    flex-wrap: wrap;
  }

  .word {
    display: inline-block;
    opacity: 0;
    animation: word-reveal 0.6s ease forwards;
  }

  @keyframes word-reveal {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-role {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent-projects);
    letter-spacing: 0.02em;
    margin-bottom: 12px;
  }

  .hero-tagline {
    color: var(--text-muted);
    font-size: 1rem;
    margin-bottom: 16px;
    max-width: 480px;
    margin-left: 0;
    transition: opacity 0.4s ease;
  }

  .hero-gradient-line {
    width: 40px;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-papers), var(--accent-projects));
    margin: 16px 0;
    border-radius: 2px;
  }

  .hero-social {
    display: flex;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
  }

  .social-pill {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    padding: 6px 14px;
    border: 1px solid var(--card-border);
    border-radius: 20px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .social-pill:hover {
    color: var(--text-primary);
    border-color: color-mix(in srgb, var(--text-primary) 25%, transparent);
  }

  /* Card content */
  .card-title {
    font-weight: 600;
    color: var(--text-heading);
    font-size: 1rem;
    line-height: 1.4;
    margin-bottom: 6px;
  }

  .card-meta {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Blog section */
  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .blog-card-inner {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .blog-date {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent-blog);
  }

  .life-teaser {
    font-style: italic;
  }

  /* Layout helpers */
  .cards-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .cards-grid {
      gap: 12px;
    }
  }

  @media (max-width: 768px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const taglines: Record<string, string[]> = {
    en: [
      'I build agents that do things, then write about what that means.',
      'From transportation ML to supply chain agents.',
      'The marginal cost of software is going to zero. That changes everything.',
    ],
    zh: [
      '造能干活的 Agent，然后想想这意味着什么。',
      '从交通 ML 到供应链 Agent。',
      '软件的边际成本正在趋近于零。这改变了一切。',
    ],
  };
  let idx = 0;
  let tagTimeout: ReturnType<typeof setTimeout>;

  function rotateTags() {
    const el = document.getElementById('hero-tagline');
    if (!el) return;
    el.style.opacity = '0';
    tagTimeout = setTimeout(() => {
      idx = (idx + 1) % taglines.en.length;
      el.innerHTML = `<span class="lang-en">${taglines.en[idx]}</span><span class="lang-zh">${taglines.zh[idx]}</span>`;
      el.style.opacity = '1';
      tagTimeout = setTimeout(rotateTags, 4000);
    }, 400);
  }

  document.addEventListener('astro:page-load', () => {
    clearTimeout(tagTimeout);
    idx = 0;
    tagTimeout = setTimeout(rotateTags, 4000);
  });
</script>
