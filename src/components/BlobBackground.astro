---
import { background } from '../config/site';
---

{background.image && <div class="bg-image-container"></div>}
<svg class="grain-overlay" aria-hidden="true">
  <filter id="grain">
    <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/>
    <feColorMatrix type="saturate" values="0"/>
  </filter>
  <rect width="100%" height="100%" filter="url(#grain)" opacity="0.04" style="mix-blend-mode: overlay;"/>
</svg>

<style
  define:vars={{
    'bg-img': background.image ? `url('${background.image}')` : 'none',
    'bg-size': background.size,
    'bg-pos': background.position,
    'bg-overlay-dark': String(background.overlay.dark),
    'bg-overlay-light': String(background.overlay.light),
  }}
>
  .bg-image-container {
    position: fixed;
    inset: 0;
    z-index: -2;
    background-image: var(--bg-img);
    background-size: var(--bg-size);
    background-position: var(--bg-pos);
    background-repeat: no-repeat;
  }

  /* Semi-transparent overlay so theme colors blend with the image */
  .bg-image-container::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--bg-primary);
    opacity: var(--bg-overlay-dark);
    transition: opacity 0.3s ease, background 0.3s ease;
  }

  [data-theme="light"] .bg-image-container::after {
    opacity: var(--bg-overlay-light);
  }

  .grain-overlay {
    position: fixed;
    inset: 0;
    z-index: -1;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>
