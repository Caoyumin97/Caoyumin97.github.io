---
import { background } from '../config/site';
---

{background.image && <div class="bg-image-container"></div>}
<div class="blob-container">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
</div>

<style
  define:vars={{
    'bg-img': background.image ? `url('${background.image}')` : 'none',
    'bg-size': background.size,
    'bg-pos': background.position,
    'bg-overlay-dark': String(background.overlay.dark),
    'bg-overlay-light': String(background.overlay.light),
  }}
>
  .bg-image-container {
    position: fixed;
    inset: 0;
    z-index: -2;
    background-image: var(--bg-img);
    background-size: var(--bg-size);
    background-position: var(--bg-pos);
    background-repeat: no-repeat;
  }

  /* Semi-transparent overlay so theme colors blend with the image */
  .bg-image-container::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--bg-primary);
    opacity: var(--bg-overlay-dark);
    transition: opacity 0.3s ease, background 0.3s ease;
  }

  [data-theme="light"] .bg-image-container::after {
    opacity: var(--bg-overlay-light);
  }

  .blob-container {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    animation: blob-drift 25s ease-in-out infinite alternate;
  }

  .blob-1 {
    width: 500px;
    height: 400px;
    top: -15%;
    left: -10%;
    background: rgba(167, 139, 250, 0.07);
  }

  .blob-2 {
    width: 450px;
    height: 350px;
    bottom: -15%;
    right: -8%;
    background: rgba(110, 231, 183, 0.05);
    animation-delay: -8s;
  }

  .blob-3 {
    width: 400px;
    height: 300px;
    top: 40%;
    right: 20%;
    background: rgba(251, 191, 36, 0.04);
    animation-delay: -15s;
  }

  /* Light mode: reduce blob opacities */
  [data-theme="light"] .blob-1 {
    background: rgba(167, 139, 250, 0.04);
  }

  [data-theme="light"] .blob-2 {
    background: rgba(110, 231, 183, 0.03);
  }

  [data-theme="light"] .blob-3 {
    background: rgba(251, 191, 36, 0.02);
  }

  @keyframes blob-drift {
    0% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(30px, -20px) scale(1.05);
    }
    66% {
      transform: translate(-20px, 30px) scale(0.95);
    }
    100% {
      transform: translate(20px, 10px) scale(1.03);
    }
  }
</style>
