---
interface Props {
  href?: string;
  accent?: string;
  class?: string;
}

const { href, accent, class: className } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={['glass-card', className]}
  style={accent ? `--tile-accent: ${accent};` : undefined}
>
  <slot />
</Tag>

<style>
  .glass-card {
    background: var(--bg-card);
    border: 1px solid var(--card-border);
    border-radius: 16px;
    padding: 24px;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .glass-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--tile-accent, white) 25%, transparent);
  }

  a.glass-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }
</style>
