---
import ThemeToggle from './ThemeToggle.astro';
import LanguageToggle from './LanguageToggle.astro';

const currentPath = Astro.url.pathname;

const links = [
  { href: '/', en: 'Home', zh: '首页' },
  { href: '/papers', en: 'Papers', zh: '论文' },
  { href: '/projects', en: 'Projects', zh: '项目' },
  { href: '/blog', en: 'Blog', zh: '博客' },
  { href: '/life', en: 'Life', zh: '生活' },
  { href: '/about', en: 'About', zh: '关于' },
];
---

<nav class="navbar">
  <div class="navbar-pill">
    <a href="/" class="navbar-logo">YC</a>
    <ul class="navbar-links">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav-link', { active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
          >
            <span class="lang-en">{link.en}</span><span class="lang-zh">{link.zh}</span>
          </a>
        </li>
      ))}
    </ul>
    <div class="navbar-actions">
      <LanguageToggle />
      <ThemeToggle />
    </div>
    <button class="navbar-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="hamburger"></span>
    </button>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    padding: 12px 16px;
  }

  .navbar-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    max-width: 640px;
    width: 100%;
    padding: 0 10px;
    height: 48px;
    border-radius: 16px;
    background: var(--navbar-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .navbar-logo {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-heading);
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }

  .navbar-links {
    display: flex;
    list-style: none;
    gap: 2px;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    padding: 6px 10px;
    border-radius: 8px;
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color 0.2s, background 0.2s;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--text-heading);
    background: rgba(128, 128, 128, 0.1);
  }

  .nav-link.active {
    color: var(--text-heading);
    background: rgba(128, 128, 128, 0.12);
  }

  .navbar-actions {
    display: flex;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
  }

  .navbar-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .hamburger {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text-primary);
    position: relative;
    transition: background 0.2s;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    width: 20px;
    height: 2px;
    background: var(--text-primary);
    left: 0;
    transition: transform 0.3s;
  }

  .hamburger::before { top: -6px; }
  .hamburger::after { top: 6px; }

  @media (max-width: 768px) {
    .navbar {
      padding: 0;
      background: var(--navbar-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    .navbar-pill {
      max-width: 100%;
      border-radius: 0;
      background: none;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      padding: 0 16px;
      height: 56px;
      justify-content: space-between;
    }

    .navbar-links {
      display: none;
      position: absolute;
      top: 56px;
      left: 0;
      right: 0;
      background: var(--navbar-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      flex-direction: column;
      padding: 8px;
      border-radius: 0 0 12px 12px;
      border: 1px solid var(--card-border);
      border-top: none;
      margin-right: 0;
      flex: unset;
      justify-content: unset;
    }

    .navbar-links.open {
      display: flex;
    }

    .navbar-links .nav-link {
      padding: 12px 16px;
    }

    .navbar-toggle {
      display: block;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const toggle = document.querySelector('.navbar-toggle');
    const nav = toggle?.closest('.navbar');
    const links = document.querySelector('.navbar-links');
    if (toggle && links) {
      toggle.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        links.classList.toggle('open');
        if (!expanded && links.querySelector('a')) {
          links.querySelector('a').focus();
        }
      });

      // Close on Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && links.classList.contains('open')) {
          links.classList.remove('open');
          toggle.setAttribute('aria-expanded', 'false');
          toggle.focus();
        }
      });

      // Close on click outside
      document.addEventListener('click', (e) => {
        if (links.classList.contains('open') && nav && !nav.contains(e.target)) {
          links.classList.remove('open');
          toggle.setAttribute('aria-expanded', 'false');
        }
      });
    }
  });
</script>
