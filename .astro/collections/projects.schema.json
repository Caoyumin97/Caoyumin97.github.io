{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "tech": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "github": {
      "type": "string"
    },
    "demo": {
      "type": "string"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "lang": {
      "default": "en",
      "type": "string",
      "enum": [
        "en",
        "zh"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "tech",
    "featured",
    "lang"
  ],
  "additionalProperties": false
}